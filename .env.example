# Database - PostgreSQL (required for production/Vercel)
# Get a free PostgreSQL database from:
#   - Neon: https://neon.tech (recommended for Vercel)
#   - Supabase: https://supabase.com
#   - Railway: https://railway.app
DATABASE_URL="postgresql://username:password@host:5432/cricket_league?sslmode=require"

# For Neon/Supabase with connection pooling, also set DIRECT_URL:
DIRECT_URL="postgresql://username:password@host:5432/cricket_league?sslmode=require"

# For LOCAL development with SQLite, use:
# DATABASE_URL="file:./dev.db"


# And change schema.prisma provider to "sqlite" (remove directUrl line)

# NextAuth
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
